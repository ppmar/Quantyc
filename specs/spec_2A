## 4. Schemas

### 4.1 Dataclasses (`parsers/appendix_2a_schemas.py`)

```python
from dataclasses import dataclass, field
from datetime import date, datetime
from decimal import Decimal
from typing import Optional, Literal

@dataclass(frozen=True)
class QuotedClass:
    """One row of Part 4.1 — a quoted security class (almost always ordinary shares)."""
    asx_code: str                          # e.g. "HTG"
    description: str                       # e.g. "ORDINARY FULLY PAID"
    total_on_issue: int

@dataclass(frozen=True)
class UnquotedInstrument:
    """One row of Part 4.2 — an unquoted option, convertible note, or performance right."""
    asx_code: str                          # e.g. "HTGAU"
    description: str                       # full raw description, verbatim
    instrument_type: Literal["option", "convertible_note", "performance_right", "other"]
    total_on_issue: int                    # face count
    expiry_date: Optional[date]            # None for CNs, some perf rights
    strike_aud: Optional[Decimal]          # None for CNs, perf rights
    raw_line: str                          # original PDF line for audit

@dataclass(frozen=True)
class Appendix2ACapitalStructure:
    # provenance
    ticker: str
    doc_id: str
    snapshot_date: date                    # passed in by caller from ASX API metadata
    parsed_at: datetime
    parser_version: str                    # semver, bump on any schema change

    # Part 4.1
    quoted_classes: list[QuotedClass]

    # Part 4.2
    unquoted_instruments: list[UnquotedInstrument]

    # derived totals (computed in parser, not pulled from doc)
    shares_basic: int                       # = sum(QuotedClass.total_on_issue)
    shares_fd_naive: int                    # = basic + sum(unquoted.total_on_issue)
    options_outstanding: int                # sum where type == "option"
    convertible_notes_face_count: int       # sum where type == "convertible_note"
    performance_rights_count: int           # sum where type == "performance_right"

    # diagnostics
    extraction_warnings: list[str] = field(default_factory=list)
```

